# ============================================================================
# RWA INMOTOKEN - VARIABLES DE ENTORNO PARA PRODUCCIÓN
# ============================================================================

# ============================================================================
# THIRDWEB CONFIGURATION (REQUIRED)
# ============================================================================
# Get from: https://thirdweb.com/dashboard/settings/api-keys
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id_here
THIRDWEB_SECRET_KEY=your_secret_key_here

# ============================================================================
# CLIENT CONFIGURATION (REQUIRED - Configure per deployment)
# ============================================================================
# Owner wallet address for admin access (client's admin wallet)
# This address will have full admin privileges (project creation, KYC approval, payouts)
NEXT_PUBLIC_OWNER_ADDRESS=0xYourClientAdminWalletAddress

# ============================================================================
# BLOCKCHAIN CONFIGURATION (Polygon Mainnet ONLY)
# ============================================================================
NEXT_PUBLIC_CHAIN_ID=137

# ============================================================================
# SMART CONTRACTS - POLYGON MAINNET (From deployment)
# ============================================================================
# Update these addresses after deploying contracts via:
# cd contracts && npx hardhat run scripts/deploy-full-platform.ts --network polygon
NEXT_PUBLIC_PROJECT_REGISTRY=0xd1d027675babfd30baf60acf4fc3cbdbf011562d
NEXT_PUBLIC_PROJECT_FACTORY=0x02ac9e3473abc7daea0899f5725f94abc89d8f69
NEXT_PUBLIC_IDENTITY_REGISTRY=0x41391dd49fef214ccccefa3c0e7e5a8f7061b266
NEXT_PUBLIC_IDENTITY_REGISTRY_STORAGE=0x869a0e897f0a71d7b8034d44832921a4a1ded14f
NEXT_PUBLIC_COMPLIANCE=0xdff331ec826b05fb22f3b2641addb22d89aeb894
NEXT_PUBLIC_CLAIM_TOPICS_REGISTRY=0xe94cb3fe19c042c3f0daed36b62a628c0efd7894
NEXT_PUBLIC_TRUSTED_ISSUERS_REGISTRY=0x5e912cbec598f0a506986f673a1b10054fd106f9

# USDC Token (Polygon Mainnet)
NEXT_PUBLIC_USDC=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

# Chainlink Price Feeds (Polygon Mainnet)
NEXT_PUBLIC_EUR_USD_FEED=0x73366Fe0AA0Ded304479862808e02506FE556a98

# ============================================================================
# API BACKEND (OPTIONAL - Client managed)
# ============================================================================
# Backend API URL for KYC and admin features
# Clients can implement their own KYC API or use thirdweb Engine
NEXT_PUBLIC_API_URL=http://localhost:3004

# ============================================================================
# DEPLOYMENT INSTRUCTIONS (Vercel)
# ============================================================================
# 1. Create thirdweb account: https://thirdweb.com/dashboard
# 2. Get Client ID from API Keys section
# 3. In Vercel Project Settings → Environment Variables add:
#    - NEXT_PUBLIC_THIRDWEB_CLIENT_ID (from step 2)
#    - NEXT_PUBLIC_OWNER_ADDRESS (client's admin wallet)
#    - All contract addresses from deployment
# 4. Deploy automatically from GitHub
# 5. Platform is LIVE on Polygon Mainnet! 🚀
# ============================================================================

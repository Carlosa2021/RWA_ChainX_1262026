# ============================================================================
# ChainX® RWA Platform — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is protected by .gitignore.
# ============================================================================

# ============================================================================
# THIRDWEB (Required)
# Get from: https://thirdweb.com/dashboard/settings/api-keys
# ============================================================================
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id_here
THIRDWEB_SECRET_KEY=your_secret_key_here

# ============================================================================
# CLIENT / OPERATOR (Required — configure per deployment)
# ============================================================================
NEXT_PUBLIC_OWNER_ADDRESS=0xYourClientAdminWalletAddress

# ============================================================================
# SaaS TIER (Required)
# Options: STARTER | PRO | ENTERPRISE
# ============================================================================
NEXT_PUBLIC_PLAN_TYPE=ENTERPRISE
NEXT_PUBLIC_LICENSE_KEY=your_license_key_here

# ============================================================================
# BLOCKCHAIN — Polygon Mainnet ONLY
# ============================================================================
NEXT_PUBLIC_CHAIN_ID=137
NEXT_PUBLIC_USDC=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
NEXT_PUBLIC_EUR_USD_FEED=0x73366Fe0AA0Ded304479862808e02506FE556a98

# ============================================================================
# SMART CONTRACTS — Polygon Mainnet (from your deployment)
# Deploy via: cd contracts && npx thirdweb deploy -k $THIRDWEB_SECRET_KEY
# ============================================================================
NEXT_PUBLIC_PROJECT_REGISTRY=0x_your_project_registry_address
NEXT_PUBLIC_IDENTITY_REGISTRY=0x_your_identity_registry_address
NEXT_PUBLIC_COMPLIANCE=0x_your_compliance_address
NEXT_PUBLIC_PROJECT_FACTORY=0x_your_factory_address
NEXT_PUBLIC_IDENTITY_REGISTRY_STORAGE=0x_your_irs_address
NEXT_PUBLIC_CLAIM_TOPICS_REGISTRY=0x_your_ctr_address
NEXT_PUBLIC_TRUSTED_ISSUERS_REGISTRY=0x_your_tir_address

# ============================================================================
# POSTGRES (Optional — enables persistent multi-tenant data)
#
# When POSTGRES_URL is set: tenant/domain resolution reads from Vercel Postgres.
# When absent: repositories fall back to static in-memory registries (mock mode).
#
# POSTGRES_URL       — pooled connection (used at runtime by the application)
# POSTGRES_URL_NON_POOLING — direct connection (required by: npm run db:seed)
#
# Provision via: Vercel dashboard → Storage → Create Database → Postgres
# ============================================================================
POSTGRES_URL=postgres://username:password@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://username:password@host/dbname?sslmode=require

# ============================================================================
# EMAIL NOTIFICATIONS (Optional — via Resend)
# Get API key: https://resend.com/api-keys  — PRIVATE, server-side only
# ============================================================================
RESEND_API_KEY=re_your_resend_api_key
CHAINX_ADMIN_EMAIL=admin@yourdomain.com
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# BACKEND API (Optional — if using the api/ Express backend)
# ============================================================================
NEXT_PUBLIC_API_URL=https://your-api-domain.com

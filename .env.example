# ============================================================================
# RWA INMOTOKEN - VARIABLES DE ENTORNO PARA PRODUCCIÓN
# ============================================================================

# ============================================================================
# THIRDWEB CONFIGURATION (REQUERIDO)
# ============================================================================
# Obtener en: https://thirdweb.com/dashboard/settings/api-keys
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id_here
THIRDWEB_SECRET_KEY=your_secret_key_here

# ============================================================================
# DEMO MODE - PARA SHOWCASE PÚBLICO (REQUERIDO PARA DEMO)
# ============================================================================
# true = Todos los usuarios tienen acceso admin y KYC verificado (PERFECTO PARA VENTAS)
# false = Solo owner real y usuarios KYC verificados
NEXT_PUBLIC_DEMO_MODE=true

# ============================================================================
# OWNER CONFIGURATION
# ============================================================================
# Owner wallet address (for admin access)
NEXT_PUBLIC_OWNER_ADDRESS=0xYourWalletAddressHere

# ============================================================================
# API BACKEND (OPCIONAL)
# ============================================================================
# Backend API URL (for KYC and Admin features)
NEXT_PUBLIC_API_URL=http://localhost:3004

# ============================================================================
# SMART CONTRACTS - POLYGON MAINNET (YA CONFIGURADOS)
# ============================================================================
NEXT_PUBLIC_PROJECT_REGISTRY=0xd1d027675babfd30baf60acf4fc3cbdbf011562d
NEXT_PUBLIC_PROJECT_FACTORY=0x02ac9e3473abc7daea0899f5725f94abc89d8f69
NEXT_PUBLIC_IDENTITY_REGISTRY=0x41391dd49fef214ccccefa3c0e7e5a8f7061b266
NEXT_PUBLIC_IDENTITY_REGISTRY_STORAGE=0x869a0e897f0a71d7b8034d44832921a4a1ded14f
NEXT_PUBLIC_COMPLIANCE=0xdff331ec826b05fb22f3b2641addb22d89aeb894
NEXT_PUBLIC_CLAIM_TOPICS_REGISTRY=0xe94cb3fe19c042c3f0daed36b62a628c0efd7894
NEXT_PUBLIC_TRUSTED_ISSUERS_REGISTRY=0x5e912cbec598f0a506986f673a1b10054fd106f9

# ============================================================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# ============================================================================
# 1. Crear cuenta en thirdweb.com/dashboard
# 2. Crear nuevo proyecto y obtener Client ID
# 3. En Vercel Project Settings → Environment Variables añadir:
#    - NEXT_PUBLIC_THIRDWEB_CLIENT_ID = tu-client-id-real
#    - NEXT_PUBLIC_DEMO_MODE = true
#    - NEXT_PUBLIC_OWNER_ADDRESS = tu-wallet-address
# 4. Deploy automático desde GitHub
# 5. ¡Tu plataforma AI + Payments estará LIVE! 🚀
# ============================================================================
